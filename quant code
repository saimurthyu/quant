# CELL 17 ── MONTE CARLO STRESS TEST
# ═════════════════════════════════════════════════════════════════════════════
def monte_carlo(trades_df, account, n_sim=2000, ci=0.95):
    """
    Randomly shuffles trade sequence N times to test whether the
    strategy's performance is genuine edge or sequence luck.

    Key outputs:
      - Distribution of final equity
      - Distribution of max drawdown
      - % of simulations beaten by actual result (significance)
      - 95% worst-case drawdown (planning metric)
    """
    if trades_df.empty:
        print("⚠️  No trades for Monte Carlo."); return None

    pnls    = trades_df["pnl"].values
    results = []

    for _ in range(n_sim):
        shuffled  = np.random.permutation(pnls)
        eq_curve  = account + np.cumsum(shuffled)
        final_eq  = eq_curve[-1]
        run_max   = np.maximum.accumulate(eq_curve)
        max_dd    = ((run_max - eq_curve) / run_max).max() * 100
        results.append({"final_equity": final_eq, "max_dd": max_dd})

    res        = pd.DataFrame(results)
    actual_eq  = trades_df["equity"].iloc[-1]
    actual_dd  = ((trades_df["equity"].cummax() - trades_df["equity"]) /
                   trades_df["equity"].cummax()).max() * 100
    pct_beat   = (res["final_equity"] < actual_eq).mean() * 100
    dd_ci      = np.percentile(res["max_dd"],         ci * 100)
    eq_ci_lo   = np.percentile(res["final_equity"], (1-ci) * 100)

    print(f"\n🎲 Monte Carlo ({n_sim:,} simulations)")
    print("─" * 48)
    print(f"  Actual final equity:         ${actual_eq:,.0f}")
    print(f"  MC median equity:            ${res['final_equity'].median():,.0f}")
    print(f"  {ci*100:.0f}% CI lower bound equity:  ${eq_ci_lo:,.0f}")
    print(f"  Actual beats {pct_beat:.1f}% of shuffles")
    print(f"  Actual max DD:               {actual_dd:.1f}%")
    print(f"  {ci*100:.0f}% worst-case MC drawdown:  {dd_ci:.1f}%")
    verdict = "✅ Genuine edge" if pct_beat > 70 else "⚠️  May be overfit — review logic"
    print(f"\n  Verdict: {verdict}")

    fig, axes = plt.subplots(1, 2, figsize=(14, 5))

    axes[0].hist(res["final_equity"], bins=60,
                 color="#534AB7", alpha=0.55, edgecolor="none")
    axes[0].axvline(actual_eq,  color="#1D9E75", lw=2,
                    label=f"Actual  ${actual_eq:,.0f}")
    axes[0].axvline(eq_ci_lo,   color="#E24B4A", lw=1.5, linestyle="--",
                    label=f"95% CI  ${eq_ci_lo:,.0f}")
    axes[0].set_title("Distribution — Final Equity", fontweight="bold")
    axes[0].set_xlabel("Final equity ($)"); axes[0].legend(fontsize=9)

    axes[1].hist(res["max_dd"], bins=60,
                 color="#D85A30", alpha=0.55, edgecolor="none")
    axes[1].axvline(actual_dd, color="#1D9E75", lw=2,
                    label=f"Actual DD  {actual_dd:.1f}%")
    axes[1].axvline(dd_ci,     color="#E24B4A", lw=1.5, linestyle="--",
                    label=f"95% worst  {dd_ci:.1f}%")
    axes[1].set_title("Distribution — Max Drawdown", fontweight="bold")
    axes[1].set_xlabel("Max drawdown (%)"); axes[1].legend(fontsize=9)

    plt.suptitle("Monte Carlo Stress Test", fontsize=13, fontweight="bold")
    plt.tight_layout()
    plt.savefig("monte_carlo.png", dpi=150, bbox_inches="tight")
    plt.show()
    return res

