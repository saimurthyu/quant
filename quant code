# CELL 11 ── LAYER 7: HMM REGIME DETECTION
# ═════════════════════════════════════════════════════════════════════════════
def hmm_regime(df, n_states=3):
    """
    3-state Hidden Markov Model on log returns + ATR:
      State 0 = Low vol / range       → tradeable
      State 1 = Trending / directional → tradeable
      State 2 = High vol / news spike  → avoid (sit out)

    States sorted by volatility so labels are stable across runs.
    """
    log_ret = np.log(df["close"] / df["close"].shift(1)).fillna(0)
    atr_ser = ta.volatility.AverageTrueRange(
        df["high"], df["low"], df["close"], 14
    ).average_true_range().fillna(method="bfill")

    X = StandardScaler().fit_transform(
        np.column_stack([log_ret.values, (atr_ser / df["close"]).values])
    )
    mdl = GaussianHMM(
        n_components=n_states, covariance_type="full",
        n_iter=300, random_state=42
    )
    mdl.fit(X)
    raw_states = mdl.predict(X)

    # Sort states by volatility (stable labelling)
    state_vol = {s: atr_ser.values[raw_states == s].mean() for s in range(n_states)}
    rank      = sorted(state_vol, key=state_vol.get)
    remap     = {old: new for new, old in enumerate(rank)}
    df["hmm_state"]    = np.vectorize(remap.get)(raw_states)
    df["hmm_trade_ok"] = (df["hmm_state"] < 2).astype(int)   # avoid state 2

