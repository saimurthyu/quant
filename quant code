# CELL 13 ── KELLY CRITERION POSITION SIZING
# ═════════════════════════════════════════════════════════════════════════════
def kelly_position_size(df, account, kelly_frac, base_risk):
    """
    Estimates optimal risk fraction via Kelly Criterion from signal history,
    then scales by ATR to reduce size in volatile conditions.
    """
    fwd    = df["close"].shift(-CFG["forward_bars"]) / df["close"] - 1
    sig_r  = fwd[df.get("signal", pd.Series(0, index=df.index)) == 1].dropna()

    if len(sig_r) < 10:
        df["risk_usd"] = account * base_risk
        print("⚠️  Not enough signal history for Kelly — using fixed risk")
        return df

    wins   = sig_r[sig_r > 0]
    losses = sig_r[sig_r <= 0]
    if len(wins) == 0 or len(losses) == 0:
        df["risk_usd"] = account * base_risk
        return df

    wr     = len(wins) / len(sig_r)
    b      = wins.mean() / abs(losses.mean())
    q      = 1 - wr
    full_k = (b * wr - q) / b
    adj_k  = max(0, min(full_k, 0.15)) * kelly_frac

    atr_z  = (
        (df["atr_pct"] - df["atr_pct"].rolling(100).mean()) /
        df["atr_pct"].rolling(100).std()
    )
    atr_scale = (1 - 0.2 * atr_z.clip(-2, 2)).clip(0.5, 1.5)
    base_risk_used = max(adj_k, base_risk)
    df["risk_usd"] = (account * base_risk_used * atr_scale).clip(
        account * 0.003, account * 0.01
    )

    print(f"✅ Kelly sizing: full={full_k:.2%} | adj={adj_k:.2%} | "
          f"range=${df['risk_usd'].min():,.0f}–${df['risk_usd'].max():,.0f}")
    return df


