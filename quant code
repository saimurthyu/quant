# CELL 6 ── LAYER 2: LIQUIDITY SWEEP + VOLUME PROFILE
# ═════════════════════════════════════════════════════════════════════════════
def swing_highs_lows(df, n=8):
    highs, lows = [], []
    for i in range(n, len(df) - n):
        if df["high"].iloc[i] == df["high"].iloc[i-n:i+n+1].max():
            highs.append(i)
        if df["low"].iloc[i]  == df["low"].iloc[i-n:i+n+1].min():
            lows.append(i)
    return highs, lows

def rolling_vp_poc(df, bins=15, lookback=100):
    """Point of Control from rolling volume profile."""
    pocs = []
    for i in range(lookback, len(df)):
        w    = df.iloc[i - lookback:i]
        lo   = w["low"].min()
        hi   = w["high"].max()
        if hi == lo:
            pocs.append(np.nan); continue
        edges    = np.linspace(lo, hi, bins + 1)
        vol_bins = np.zeros(bins)
        for _, row in w.iterrows():
            for b in range(bins):
                if edges[b] <= row["close"] < edges[b + 1]:
                    vol_bins[b] += row["volume"]; break
        poc_idx = np.argmax(vol_bins)
        pocs.append((edges[poc_idx] + edges[poc_idx + 1]) / 2)
    df["poc"] = [np.nan] * lookback + pocs
    return df

def detect_sweeps(df, swing_h, swing_l, thresh=0.0015):
    """
    Bullish sweep: wick pierces below prior swing low → closes back above.
    Must also be near the POC (volume profile level) for confluence.
    """
    sweep = pd.Series(0, index=df.index)
    h_lvl = [(i, df["high"].iloc[i]) for i in swing_h]
    l_lvl = [(i, df["low"].iloc[i])  for i in swing_l]

    for bar in range(1, len(df)):
        rh = [v for i, v in h_lvl if i < bar]
        rl = [v for i, v in l_lvl if i < bar]
        if not rh or not rl: continue

        ll = rl[-1]
        poc_ok = (
            not pd.isna(df["poc"].iloc[bar]) and
            abs(df["close"].iloc[bar] - df["poc"].iloc[bar])
            / df["poc"].iloc[bar] < 0.004
        )
        if (df["low"].iloc[bar]   < ll * (1 - thresh) and
                df["close"].iloc[bar] > ll and poc_ok):
            sweep.iloc[bar] = 1

    n = (sweep == 1).sum()
    print(f"✅ Layer 2 — Sweeps at VP: {n} bullish sweeps found")
    return sweep

