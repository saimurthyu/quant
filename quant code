# CELL 5 ── LAYER 1: HTF BIAS FILTER
# ═════════════════════════════════════════════════════════════════════════════
def htf_bias_filter(df, df_d, ma=50):
    """
    Daily structure check:
      - Price above daily 50 MA
      - Daily making HH + HL (confirmed uptrend structure)
    Maps daily signal down to every intraday bar.
    """
    d = df_d.copy()
    d["ma"]     = d["close"].rolling(ma).mean()
    d["hh"]     = (d["high"] > d["high"].shift(1)).astype(int)
    d["hl"]     = (d["low"]  > d["low"].shift(1)).astype(int)
    d["bias"]   = (
        (d["close"] > d["ma"]) & (d["hh"] == 1) & (d["hl"] == 1)
    ).astype(int)

    bias_map = d["bias"].to_dict()
    df["htf_bias"] = df.index.normalize().map(
        lambda t: bias_map.get(pd.Timestamp(t), 0)
    ).fillna(0).astype(int)
    pct = df["htf_bias"].mean() * 100
    print(f"✅ Layer 1 — HTF bias: {pct:.1f}% of bars in bullish structure")
    return df

