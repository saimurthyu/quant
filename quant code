# CELL 16 ── PROP FIRM BACKTEST (with all execution rules)
# ═════════════════════════════════════════════════════════════════════════════
def apply_costs(price, direction, spread, slip):
    """Round-trip cost adjustment."""
    cost = spread + slip
    return price * (1 + cost) if direction == 1 else price * (1 - cost)

def get_5m_entry(df_5, signal_ts, direction=1, lookback_bars=3):
    """
    After a 1H signal fires at signal_ts, look at the next 'lookback_bars'
    5-minute bars for a precise entry trigger:
      - Bullish: first 5M bar that closes above its open (bullish confirmation)
      - Entry = close of that 5M bar
      - SL    = low of that 5M bar minus 0.5×ATR_5m (tight)

    Returns (entry_price, stop_loss, found).
    If no confirmation within lookback_bars, returns None (skip trade).
    """
    window = df_5[df_5.index > signal_ts].head(lookback_bars)
    for ts, row in window.iterrows():
        if direction == 1 and row["close"] > row["open"]:
            atr_bar = (row["high"] - row["low"])           # simple bar range as SL buffer
            entry   = row["close"] * (1 + CFG["spread_pct"] + CFG["slippage_pct"])
            sl      = row["low"] - 0.5 * atr_bar
            return entry, sl, True
        elif direction == -1 and row["close"] < row["open"]:
            atr_bar = (row["high"] - row["low"])
            entry   = row["close"] * (1 - CFG["spread_pct"] - CFG["slippage_pct"])
            sl      = row["high"] + 0.5 * atr_bar
            return entry, sl, True
    return None, None, False   # no clean 5M confirmation — skip

def propfirm_backtest(df, df_5, cfg):
    """
    Full backtest with THREE-TIMEFRAME execution:
      - 1H signal fires  → record signal timestamp
      - 5M chart         → find precise confirmation candle within next 3 bars
      - Entry / SL       → based on 5M bar (tighter stop = better R:R)
      - TP / trail       → managed on 1H bars (broader view)
      + Prop firm rules: daily/weekly DD gates, Kelly sizing
    """
    account      = cfg["account_size"]
    equity       = account
    peak_eq      = account
    trades       = []
    daily_pnl    = {}
    weekly_pnl   = {}
    in_trade     = False
    entry_p = sl = trail_sl = 0.0
    entry_bar    = 0
    remaining    = 1.0
    tp1_done     = False
    be_done      = False

    prices  = df["close"].values
    highs   = df["high"].values
    lows    = df["low"].values
    atrs    = ta.volatility.AverageTrueRange(
        df["high"], df["low"], df["close"], 14
    ).average_true_range().fillna(method="bfill").values
    sigs    = df["signal"].values
    risks   = df["risk_usd"].values
    dates   = df.index

    def dkey(ts): return ts.date()
    def wkey(ts): return (ts.year, ts.isocalendar()[1])

    for i in range(len(df) - cfg["max_bars_hold"] - 2):
        d, w = dkey(dates[i]), wkey(dates[i])
        daily_pnl.setdefault(d, 0.0)
        weekly_pnl.setdefault(w, 0.0)

        # ── Prop firm gates ──
        if daily_pnl[d]  <= -account * cfg["daily_dd_gate"]:  continue
        if weekly_pnl[w] <= -account * cfg["weekly_dd_gate"]: continue
        if (peak_eq - equity) / peak_eq >= cfg["max_dd"] - 0.01: break

        if not in_trade and sigs[i] == 1:
            # ── 5M execution: find precise entry candle ──────────────────
            signal_ts = dates[i]
            entry_p, sl, found = get_5m_entry(df_5, signal_ts, direction=1)

            if not found:
                # No clean 5M confirmation within 3 bars — skip this signal
                continue

            risk_$      = risks[i]
            R           = entry_p - sl          # R based on 5M bar range
            if R <= 0:
                continue                        # invalid setup, skip
            trail_sl    = sl
            entry_bar   = i
            remaining   = 1.0
            tp1_done    = False
            be_done     = False
            in_trade    = True

        if in_trade:
            # Update trailing stop
            peak_p   = max(prices[entry_bar:i+1])
            trail_sl = max(trail_sl, peak_p - cfg["tp2_trail_atr"] * atrs[i])

            # Breakeven move
            R = entry_p - sl
            if not be_done and prices[i] >= entry_p + cfg["be_trigger_r"] * R:
                trail_sl = max(trail_sl, entry_p)
                be_done  = True

            # TP1: partial exit at 1.5R
            tp1_price = entry_p + cfg["tp1_r"] * R
            tp1_pnl   = 0.0
            if not tp1_done and highs[i] >= tp1_price:
                exit_p  = apply_costs(tp1_price, -1,
                          cfg["spread_pct"], cfg["slippage_pct"])
                tp1_pnl = (exit_p / entry_p - 1) * cfg["tp1_size"] * risk_$
                remaining -= cfg["tp1_size"]
                tp1_done  = True

            # Stop hit (trailing or original SL)
            eff_sl = max(trail_sl, sl)
            if lows[i] < eff_sl:
                exit_p  = apply_costs(eff_sl, -1,
                          cfg["spread_pct"], cfg["slippage_pct"])
                sl_pnl  = (exit_p / entry_p - 1) * remaining * risk_$
                total   = tp1_pnl + sl_pnl
                equity += total; peak_eq = max(peak_eq, equity)
                daily_pnl[d]  = daily_pnl.get(d,  0) + total
                weekly_pnl[w] = weekly_pnl.get(w, 0) + total
                trades.append({"pnl": total, "equity": equity,
                               "win": total > 0, "type": "SL",
                               "bars": i - entry_bar})
                in_trade = False; continue

            # Time exit
            if i >= entry_bar + cfg["max_bars_hold"]:
                exit_p  = apply_costs(prices[i], -1,
                          cfg["spread_pct"], cfg["slippage_pct"])
                te_pnl  = (exit_p / entry_p - 1) * remaining * risk_$
                total   = tp1_pnl + te_pnl
                equity += total; peak_eq = max(peak_eq, equity)
                daily_pnl[d]  = daily_pnl.get(d,  0) + total
                weekly_pnl[w] = weekly_pnl.get(w, 0) + total
                trades.append({"pnl": total, "equity": equity,
                               "win": total > 0, "type": "Time",
                               "bars": i - entry_bar})
                in_trade = False

    t = pd.DataFrame(trades)
    if t.empty:
        print("⚠️  No trades recorded."); return t, {}

    wins = t[t["win"]];  loss = t[~t["win"]]
    wr   = len(wins) / len(t) * 100
    avg_w = wins["pnl"].mean() if len(wins) else 0
    avg_l = abs(loss["pnl"].mean()) if len(loss) else 1
    rr    = avg_w / avg_l if avg_l else 0
    ret   = (t["equity"].iloc[-1] / account - 1) * 100
    mdd   = ((t["equity"].cummax() - t["equity"]) /
              t["equity"].cummax()).max() * 100
    worst_day = min(daily_pnl.values()) / account * 100 if daily_pnl else 0

    stats = {
        "Total trades":     len(t),
        "Win rate %":       round(wr, 2),
        "Avg R:R":          round(rr, 2),
        "Total return %":   round(ret, 2),
        "Max drawdown %":   round(mdd, 2),
        "Worst day %":      round(worst_day, 2),
        "Final equity $":   round(t["equity"].iloc[-1], 2),
        "Challenge passed": (
            "✅ YES" if ret >= 10 and mdd < 10
                        and wr >= 60 and worst_day > -5
            else "❌ NOT YET"
        ),
    }

    print("\n📊 Prop Firm Backtest Results")
    print("═" * 42)
    targets = {
        "Win rate %": (60, ">="),
        "Avg R:R":    (1.5, ">="),
        "Total return %": (10, ">="),
        "Max drawdown %": (10, "<"),
        "Worst day %":    (-5, ">"),
    }
    for k, v in stats.items():
        flag = ""
        if k in targets:
            thresh, op = targets[k]
            flag = " ✅" if (
                (op == ">=" and v >= thresh) or
                (op == "<"  and v <  thresh) or
                (op == ">"  and v >  thresh)
            ) else " ❌"
        print(f"  {k:<22}: {v}{flag}")

    return t, stats

