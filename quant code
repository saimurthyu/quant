# CELL 7 ── LAYER 3: ORDER FLOW IMBALANCE (Delta, CVD, Bid-Ask Pressure)
# ═════════════════════════════════════════════════════════════════════════════
def order_flow_imbalance(df):
    """
    Tick-data proxy using bar anatomy:
      up_vol   ≈ vol * (close - low)  / (high - low)
      dn_vol   ≈ vol * (high - close) / (high - low)
      delta    = up_vol - dn_vol
      CVD      = cumulative delta (resets daily)
      BA press = delta / (ATR * close)  → signed pressure score

    Replace with real tick delta from broker API for live trading.
    """
    hl = (df["high"] - df["low"]).replace(0, np.nan)
    df["up_vol"]      = df["volume"] * (df["close"] - df["low"])  / hl
    df["dn_vol"]      = df["volume"] * (df["high"]  - df["close"]) / hl
    df["delta"]       = df["up_vol"] - df["dn_vol"]
    df["cvd"]         = df.groupby(df.index.date)["delta"].cumsum()
    df["cvd_slope"]   = df["cvd"].diff(4)

    atr = ta.volatility.AverageTrueRange(
        df["high"], df["low"], df["close"], 14
    ).average_true_range()
    df["ba_pressure"] = df["delta"] / (atr * df["close"]).replace(0, np.nan)

    # OFI signal: all three bullish
    df["ofi_bull"] = (
        (df["delta"]     > 0) &
        (df["cvd_slope"] > 0) &
        (df["ba_pressure"] > 0)
    ).astype(int)

    print(f"✅ Layer 3 — OFI: {df['ofi_bull'].sum()} bullish OFI bars")
    return df

df = order_flow_imbalance(df)


