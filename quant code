# CELL 8 ── LAYER 4: OPEN INTEREST + FUNDING PROXY
# ═════════════════════════════════════════════════════════════════════════════
def oi_funding_proxy(df):
    """
    OI proxy  : rolling 20-bar volume trend (rising = new money entering)
    Funding proxy: price up but CVD flat/negative = potential squeeze risk

    For live systems replace with:
      - CME Group API (NQ futures OI)
      - Binance /fapi/v1/openInterest (crypto)
      - Bybit /v5/market/open-interest
    """
    df["oi_proxy"]     = df["volume"].rolling(20).mean()
    df["oi_rising"]    = (df["oi_proxy"] > df["oi_proxy"].shift(5)).astype(int)

    price_up          = df["close"] > df["close"].shift(5)
    cvd_flat          = df["cvd"].diff(5) < 0
    df["squeeze_risk"] = (price_up & cvd_flat).astype(int)

    df["oi_ok"] = (
        (df["oi_rising"]    == 1) &
        (df["squeeze_risk"] == 0)
    ).astype(int)

    print(f"✅ Layer 4 — OI proxy: {df['oi_ok'].sum()} favorable bars")
    return df

