def session_news_filter(df, sessions, news_window=30):
    """
    Session filter  : only trade during London (07-10 UTC) + NY open (13-16 UTC)
    News blackout   : block ±30 min around FOMC, NFP, CPI
                      Replace with live economic calendar API for production.
    """
    h        = df.index.hour
    in_sess  = pd.Series(False, index=df.index)
    for s, e in sessions:
        in_sess |= (h >= s) & (h < e)
    df["in_session"] = in_sess.astype(int)

    blocked = pd.Series(False, index=df.index)
    win     = pd.Timedelta(minutes=news_window)
    for ts in df.index:
        # NFP: first Friday each month, 13:30 UTC
        if ts.weekday() == 4 and ts.hour == 13 and ts.minute < 30:
            blocked[ts] = True
        # FOMC: approx Wed 18–19 UTC, bimonthly
        if (ts.weekday() == 2 and ts.hour in [18, 19] and
                ts.month in [1, 3, 5, 6, 7, 9, 11, 12]):
            blocked[ts] = True
        # CPI: Tue 13:30 UTC, weeks 2–3 of month
        if ts.weekday() == 1 and ts.hour == 13 and 8 <= ts.day <= 21:
            blocked[ts] = True

    df["event_ok"]   = (~blocked).astype(int)
    print(f"✅ Layer 6 — Session: {df['in_session'].mean()*100:.1f}% bars | "
          f"News blocked: {blocked.sum()} bars")
    return df

