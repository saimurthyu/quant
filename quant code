# CELL 9 ── LAYER 5: XGBOOST ML (Scheduled Walk-Forward Retraining)
# ═════════════════════════════════════════════════════════════════════════════
def build_features(df):
    """
    Full feature set including all primary edge signals + technicals.
    """
    d = df.copy()

    # Momentum
    d["rsi"]        = ta.momentum.RSIIndicator(d["close"], 14).rsi()
    d["roc_4"]      = d["close"].pct_change(4)
    d["roc_12"]     = d["close"].pct_change(12)

    # Trend
    d["ema_cross"]  = (
        ta.trend.EMAIndicator(d["close"], 8).ema_indicator() -
        ta.trend.EMAIndicator(d["close"], 21).ema_indicator()
    ) / d["close"]
    d["adx"]        = ta.trend.ADXIndicator(
        d["high"], d["low"], d["close"], 14
    ).adx()

    # Volatility
    bb             = ta.volatility.BollingerBands(d["close"], 20, 2)
    d["bb_pct"]    = bb.bollinger_pband()
    d["bb_width"]  = (bb.bollinger_hband() - bb.bollinger_lband()) / d["close"]
    d["atr_pct"]   = ta.volatility.AverageTrueRange(
        d["high"], d["low"], d["close"], 14
    ).average_true_range() / d["close"]

    # Volume
    d["vol_ratio"] = d["volume"] / d["volume"].rolling(20).mean()

    # Primary edge signals (from layers 1–4)
    d["htf_bias"]   = d["htf_bias"]
    d["sweep"]      = d["sweep"]
    d["ofi_bull"]   = d["ofi_bull"]
    d["oi_ok"]      = d["oi_ok"]
    d["delta_norm"] = d["delta"] / d["volume"].replace(0, np.nan)
    d["cvd_slope"]  = d["cvd_slope"]
    d["ba_press"]   = d["ba_pressure"]

    # Candle anatomy
    d["body"]       = abs(d["close"] - d["open"]) / d["close"]
    d["lwick"]      = (d[["close","open"]].min(axis=1) - d["low"])  / d["close"]
    d["uwick"]      = (d["high"] - d[["close","open"]].max(axis=1)) / d["close"]

    # Time
    d["hour"]       = d.index.hour
    d["dow"]        = d.index.dayofweek   # 0=Mon … 4=Fri

    FEATS = [
        "rsi", "roc_4", "roc_12", "ema_cross", "adx",
        "bb_pct", "bb_width", "atr_pct", "vol_ratio",
        "htf_bias", "sweep", "ofi_bull", "oi_ok",
        "delta_norm", "cvd_slope", "ba_press",
        "body", "lwick", "uwick", "hour", "dow",
    ]
    d.dropna(inplace=True)
    fwd          = d["close"].shift(-CFG["forward_bars"]) / d["close"] - 1
    d["target"]  = (fwd > CFG["min_move"]).astype(int)
    d.dropna(subset=["target"], inplace=True)

    pos = d["target"].mean() * 100
    print(f"✅ Features: {len(FEATS)} inputs | {len(d)} bars | {pos:.1f}% positive class")
    return d, FEATS

df, FEATS = build_features(df)


def scheduled_retrain(df, feat_cols, retrain_months=1):
    """
    Walk-forward monthly retraining.
    Simulates production: model sees only past data, retrained on schedule.
    Prevents lookahead bias and model decay.
    """
    df       = df.copy()
    df["ml_prob"] = np.nan
    months   = pd.period_range(df.index.min(), df.index.max(), freq="M")
    scaler   = StandardScaler()
    model    = XGBClassifier(
        n_estimators=400, max_depth=3, learning_rate=0.04,
        subsample=0.75, colsample_bytree=0.75,
        min_child_weight=5,
        use_label_encoder=False, eval_metric="logloss",
        random_state=42, n_jobs=-1
    )
    X    = df[feat_cols].values
    y    = df["target"].values
    trained = False

    print("Scheduled retraining walk-forward:")
    for i, month in enumerate(months):
        if i < 6: continue   # need min 6 months history

        tr_mask = df.index.to_period("M") < month
        te_mask = df.index.to_period("M") == month
        if tr_mask.sum() < 50 or te_mask.sum() == 0: continue

        if i % retrain_months == 0:
            Xtr_s = scaler.fit_transform(X[tr_mask])
            model.fit(Xtr_s, y[tr_mask], verbose=False)
            trained = True
            print(f"   Retrained on {month} | train={tr_mask.sum()} bars")

        if trained:
            Xte_s = scaler.transform(X[te_mask])
            df.loc[te_mask, "ml_prob"] = model.predict_proba(Xte_s)[:, 1]

    df.dropna(subset=["ml_prob"], inplace=True)
    scaler.fit_transform(X)
    model.fit(scaler.transform(X), y, verbose=False)

    print(f"✅ Layer 5 — ML: {df['ml_prob'].notna().sum()} OOS bars | "
          f"avg prob={df['ml_prob'].mean():.3f}")
    return df, model, scaler

df, xgb_model, scaler = scheduled_retrain(df, FEATS, CFG["retrain_months"])


