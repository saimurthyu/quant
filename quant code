# ═════════════════════════════════════════════════════════════════════════════
def correlation_filter(df, window_hours=4):
    """
    Blocks a new signal if 3 or more signals fired within the last
    `window_hours` hours (over-clustering = correlated exposure).

    For multi-asset portfolios: compute cross-asset return correlation
    and block new entries if portfolio correlation > threshold.
    """
    df["corr_blocked"] = False
    sig_times = df[df["signal"] == 1].index.tolist()

    for i in range(2, len(sig_times)):
        t_old, t_new = sig_times[i - 2], sig_times[i]
        gap_h = (t_new - t_old).total_seconds() / 3600
        if gap_h < window_hours:
            df.loc[t_new, "corr_blocked"] = True

    n_blocked = df["corr_blocked"].sum()
    df.loc[df["corr_blocked"], "signal"] = 0
    print(f"✅ Correlation filter: {n_blocked} over-clustered signals blocked | "
          f"{df['signal'].sum()} signals remain")
    return df

